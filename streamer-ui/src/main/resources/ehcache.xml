<config
        xmlns:xsi='http://www.w3.org/2001/XMLSchema-instance'
        xmlns='http://www.ehcache.org/v3'
        xsi:schemaLocation="
            http://www.ehcache.org/v3
            http://www.ehcache.org/schema/ehcache-core-3.7.xsd">

    <persistence directory="${user.home}/.streamer/cache"/>

    <cache-template name="default">
        <resources>
            <heap>1000</heap>
            <offheap unit="MB">500</offheap>
        </resources>
    </cache-template>

    <cache alias="spring.swing.icons" uses-template="default"/>

    <cache alias="spring.swing.uniform.type.identifier" uses-template="default"/>

    <cache alias="spring.swing.file.type.description" uses-template="default"/>

    <cache alias="streamer.sizes" uses-template="default"/>

    <cache alias="strava-client" uses-template="default"/>

</config>